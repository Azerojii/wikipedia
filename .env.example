# Admin Credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-password-here

# NextAuth Configuration
# Generate a secure secret: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-key-here-min-32-characters

# For local development
# NEXTAUTH_URL=http://localhost:3000

# For Vercel production - Set this in Vercel Environment Variables
# NEXTAUTH_URL=https://your-domain.vercel.app

# GitHub Integration (for production deployments on Vercel)
# Required to enable create/edit/delete articles on production
# Create a Personal Access Token at: https://github.com/settings/tokens
# Required permissions: repo (Full control of private repositories)
GITHUB_TOKEN=your_github_personal_access_token
GITHUB_OWNER=your-github-username
GITHUB_REPO=your-repo-name
GITHUB_BRANCH=main
